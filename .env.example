# Port servera (predvolene 3001)
PORT=3001
# true = bez okna prehliadača, false = zobrazí sa Chrome (na ladenie)
HEADLESS=true
# Timeout pre načítanie stránok v ms (45 s)
REQUEST_TIMEOUT_MS=45000
# Povolený CORS pôvod (* = všetky, alebo napr. https://tvoja-frontend-app.com)
ALLOWED_ORIGIN=*
# true = striktne vyžaduj konkrétny historický 4-zápasový snapshot, false = dynamická Superponuka validácia (odporúčané)
STRICT_EXPECTED_SUPERPONUKA=false
